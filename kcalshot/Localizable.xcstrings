      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "KcalShot has no server of its own; it doesn't collect, analyze, or forward any user data. The app uses an LLM API that you configure yourself."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "KcalShot 自身没有服务器，不收集、不分析、不转发任何用户数据。App 使用用户自行配置的 LLM API。"
